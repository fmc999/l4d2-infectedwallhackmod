UnlitGeneric
{
$basetexture "models\infected\spitter\spitter_color"
$bumpmap "models\infected\spitter\spitter_normal"
$phongexponenttexture "models\infected\spitter\spitter_exponent"
$phong 1
$ignorez 1
$phongboost 110
$phongexponent 5
$halflambert 1
$phongfresnelranges "[.2 .5 5]"
$ambientocclusion 1
$diffuseexp 1




$envmap env_cubemap

$phongalbedotint 1
$envmaptint "[.1 .1 .1]"



$color2 "[1 0 0]"
$selfillum 1
$selfillumtint "[1 0 0]"
}